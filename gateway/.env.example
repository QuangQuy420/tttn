# API Gateway (North-South entry point)
PORT=8080
CORS_ORIGIN=http://localhost:3000

# JWT verification at the edge
JWT_SECRET=change-me-in-.env

# Downstream services (East-West, internal REST)
AUTH_SERVICE_URL=http://auth:3001
CATALOG_SERVICE_URL=http://catalog:3002
ORDER_SERVICE_URL=http://order:3003
FACE_SERVICE_URL=http://face:8000
RECO_SERVICE_URL=http://reco:8000
