# ============================================================================
# Central environment for `docker-compose up` (LOCAL only).
# Copy to .env and adjust. Never commit the real .env.
# ============================================================================

# --- Shared ---
JWT_SECRET=change-me-in-.env

# --- PostgreSQL (one server, database-per-service) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
# Databases created on first boot by scripts/init-multiple-dbs.sh
POSTGRES_MULTIPLE_DATABASES=auth_db,catalog_db,order_db

# --- Redis ---
# (no auth in local dev)

# --- MinIO (S3-compatible object storage for face images) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
FACE_S3_BUCKET=face-images

# --- Public ports (host) ---
GATEWAY_PORT=8080
WEB_PORT=3000
