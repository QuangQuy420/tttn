# API Gateway (North-South entry point)
PORT=8080
CORS_ORIGIN=http://localhost:3000

# JWT verification at the edge
JWT_SECRET=change-me-in-.env

# Downstream services (East-West, internal REST)
USER_SERVICE_URL=http://user-service:3001
PRODUCT_SERVICE_URL=http://product-service:3002
ORDER_SERVICE_URL=http://order-service:3003
FACE_PROCESSING_SERVICE_URL=http://face-processing-service:8000
RECOMMENDATION_SERVICE_URL=http://recommendation-service:8000
